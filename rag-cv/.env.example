# ===========================================
# RAG CV System - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# LLM Provider: "openrouter" or "ollama"
LLM_PROVIDER=openrouter

# OpenRouter API Key (Required when LLM_PROVIDER=openrouter)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter Model (Optional)
# Default: deepseek/deepseek-r1:free
# Other options:
#   - openai/gpt-4o-mini
#   - anthropic/claude-3-haiku
#   - mistralai/mistral-7b-instruct:free
#   - google/gemini-2.0-flash-exp:free
OPENROUTER_MODEL=deepseek/deepseek-r1:free

# Ollama Settings (Required when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Embedding Models (Optional - defaults provided)
EMBEDDING_MODEL_A=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_MODEL_B=intfloat/e5-base-v2

# Paths (Optional - defaults provided)
CHROMA_PERSIST_DIR=data/chroma
UPLOAD_DIR=data/uploads

# Retrieval Settings (Optional)
DEFAULT_TOP_K=5

# Chunking Settings (Optional)
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# Prompt Language: "en" or "ar"
PROMPT_LANGUAGE=en

# API URL (used by Streamlit in Docker to reach the FastAPI service)
# For Docker Compose: http://api:8000
# For local dev: http://localhost:8000
API_URL=http://localhost:8000
