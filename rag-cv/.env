# ===========================================
# RAG CV System - Environment Variables
# ===========================================

# LLM Provider Configuration
# Options: "ollama" (Local) or "openrouter" (Cloud)
LLM_PROVIDER=ollama

# Ollama Configuration (Local)
# Ensure you have Ollama installed and have run: "ollama pull mistral"
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# OpenRouter API Key (Required if LLM_PROVIDER=openrouter)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=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

# OpenRouter Model (Optional)
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# Embedding Models (Optional - defaults provided)
EMBEDDING_MODEL_A=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_MODEL_B=intfloat/e5-base-v2

# Paths (Optional - defaults provided)
CHROMA_PERSIST_DIR=data/chroma
UPLOAD_DIR=data/uploads

# Retrieval Settings (Optional)
DEFAULT_TOP_K=5

# Chunking Settings (Optional)
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
